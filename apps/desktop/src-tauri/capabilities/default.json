{
  "identifier": "default",
  "description": "Default desktop window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "deep-link:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": [{ "validator": ".+" }]
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [{ "name": "node" }]
    },
    "updater:default",
    "window-state:default"
  ]
}
